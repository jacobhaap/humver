{
    "name": "@jacobhaap/humver",
    "version": "0.1.0",
    "license": "MIT",
    "exports": "./src/version.ts",
    "compilerOptions": {
        "strict": true,
        "lib": [
            "deno.ns",
            "deno.window",
            "esnext"
        ]
    },
    "lint": {
        "include": [
            "src/"
        ],
        "exclude": [
            "scripts/"
        ],
        "rules": {
            "tags": [
                "recommended"
            ]
        }
    },
    "fmt": {
        "useTabs": true,
        "lineWidth": 80,
        "indentWidth": 4,
        "semiColons": true,
        "trailingCommas": "never",
        "useBraces": "always",
        "exclude": [
            "LICENSE",
            "README.md"
        ]
    },
    "include": [
        "./src/**/*",
        "deno.json",
        "deno.lock",
        "LICENSE",
        "README.md"
    ],
    "exclude": [
        "./scripts",
        ".gitignore"
    ],
    "test": {
        "include": [
            "tests/mod.test.ts"
        ]
    },
    "imports": {
        "@deno/dnt": "jsr:@deno/dnt@0.42.3",
        "@std/assert": "jsr:@std/assert@1.0.19"
    }
}